generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  name      String
  email     String   @unique
  avatarUrl String?
  createdAt DateTime @default(now())

  roomMembers RoomMember[]
  bets        Bet[]
  specialBets SpecialBet[]
}

model Tournament {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  type      String
  season    String
  startDate DateTime
  endDate   DateTime
  logoUrl   String?
  isActive  Boolean  @default(true)

  matches Match[]
  rooms   Room[]
  teams   TournamentTeam[]
}

model Match {
  id           String      @id @default(cuid())
  tournamentId String
  homeTeam     String
  awayTeam     String
  homeTeamId   String?
  awayTeamId   String?
  kickoffAt    DateTime
  betsLockedAt DateTime
  homeScore    Int?
  awayScore    Int?
  status       MatchStatus @default(SCHEDULED)
  homeOdds     Float?
  awayOdds     Float?
  drawOdds     Float?

  tournament  Tournament @relation(fields: [tournamentId], references: [id])
  homeTeamRel Team?      @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamRel Team?      @relation("AwayTeam", fields: [awayTeamId], references: [id])
  bets        Bet[]

  @@index([tournamentId])
}

enum MatchStatus {
  SCHEDULED
  LOCKED
  LIVE
  FINISHED
  CANCELLED
  POSTPONED
}

enum TeamType {
  NATIONAL
  CLUB
}

model Team {
  id      String   @id @default(cuid())
  name    String   @unique
  type    TeamType @default(NATIONAL)
  flagUrl String?

  tournaments TournamentTeam[]
  homeMatches Match[]          @relation("HomeTeam")
  awayMatches Match[]          @relation("AwayTeam")
}

model TournamentTeam {
  tournamentId String
  teamId       String

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  team       Team       @relation(fields: [teamId], references: [id])

  @@id([tournamentId, teamId])
}

model Room {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  tournamentId  String
  createdBy     String
  scoringMode   ScoringMode @default(ODDS_BASED)
  scoringConfig Json?
  inviteCode    String      @unique
  isPublic      Boolean     @default(false)
  createdAt     DateTime    @default(now())

  tournament  Tournament   @relation(fields: [tournamentId], references: [id])
  members     RoomMember[]
  bets        Bet[]
  specialBets SpecialBet[]
}

enum ScoringMode {
  FIXED
  ODDS_BASED
  HYBRID
}

model RoomMember {
  id       String   @id @default(cuid())
  roomId   String
  userId   String
  role     Role     @default(MEMBER)
  joinedAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
}

enum Role {
  ADMIN
  MEMBER
}

model Bet {
  id            String   @id @default(cuid())
  roomId        String
  userId        String
  matchId       String
  predictedHome Int
  predictedAway Int
  pointsEarned  Float?
  oddsUsed      Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  room  Room  @relation(fields: [roomId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([roomId, userId, matchId])
  @@index([matchId])
  @@index([roomId, userId])
}

model SpecialBet {
  id           String   @id @default(cuid())
  roomId       String
  userId       String
  type         String
  prediction   String
  pointsEarned Float?
  createdAt    DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id])
  user User @relation(fields: [userId], references: [id])
}
